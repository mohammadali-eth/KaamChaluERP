<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  <display-name>KaamChaluERP</display-name>
  
    <!-- ============================= -->
    <!-- Welcome File -->
    <!-- ============================= -->
	  <welcome-file-list>
	    <welcome-file>index.html</welcome-file>
	  </welcome-file-list>
  
    <!-- ============================= -->
    <!-- Context Parameters (Global) -->
    <!-- ============================= -->
    <context-param>
        <param-name>appName</param-name>
        <param-value>KaamChaluERP</param-value>
    </context-param>
        
    <!-- ============================= -->
    <!-- Registration Servlet -->
    <!-- ============================= -->
    <servlet>
        <servlet-name>RegistrationServlet</servlet-name>
        <servlet-class>Registration.Registration</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegistrationServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    
    <!-- ============================= -->
    <!-- Login Servlet -->
    <!-- ============================= -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>Login.Login</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    
    <!-- ============================= -->
    <!-- Logout Servlet -->
    <!-- ============================= -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>Logout.Logout</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    
    <!-- ============================= -->
    <!-- Dashboard Servlet -->
    <!-- ============================= -->
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>Dashboard.Dashboard</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>
    
	 <!-- ============================= -->
	 <!-- Dashboard Servlet -->
	 <!-- ============================= -->
	  <servlet>
	    <servlet-name>InventoryServlet</servlet-name>
	    <servlet-class>Inventory.Inventory</servlet-class>
	</servlet>
	
	<servlet-mapping>
	    <servlet-name>InventoryServlet</servlet-name>
	    <url-pattern>/inventory</url-pattern>
	</servlet-mapping>

	 <!-- ============================= -->
	 <!-- Staff Servlet -->
	 <!-- ============================= -->
	<servlet>
	    <servlet-name>StaffServlet</servlet-name>
	    <servlet-class>Staff.Staff</servlet-class>
	</servlet>
	
	<servlet-mapping>
	    <servlet-name>StaffServlet</servlet-name>
	    <url-pattern>/staff</url-pattern>
	</servlet-mapping>

	 <!-- ============================= -->
	 <!-- Action Inventory Servlet -->
	 <!-- ============================= -->
	<servlet>
	    <servlet-name>DeleteInventory</servlet-name>
	    <servlet-class>Inventory.DeleteInventory</servlet-class>
	</servlet>
	
	<servlet-mapping>
	    <servlet-name>DeleteInventory</servlet-name>
	    <url-pattern>/deleteInventory</url-pattern>
	</servlet-mapping>

	<servlet>
	    <servlet-name>EditInventory</servlet-name>
	    <servlet-class>Inventory.EditInventory</servlet-class>
	</servlet>
	
	<servlet-mapping>
	    <servlet-name>EditInventory</servlet-name>
	    <url-pattern>/editInventory</url-pattern>
	</servlet-mapping>

	 <!-- ============================= -->
	 <!-- Action Staff Servlet -->
	 <!-- ============================= -->
	<servlet>
	    <servlet-name>DeleteStaff</servlet-name>
	    <servlet-class>Staff.DeleteStaff</servlet-class>
	</servlet>
	
	<servlet-mapping>
	    <servlet-name>DeleteStaff</servlet-name>
	    <url-pattern>/deleteStaff</url-pattern>
	</servlet-mapping>
	
	<servlet>
	    <servlet-name>EditStaff</servlet-name>
	    <servlet-class>Staff.EditStaff</servlet-class>
	</servlet>
	
	<servlet-mapping>
	    <servlet-name>EditStaff</servlet-name>
	    <url-pattern>/editStaff</url-pattern>
	</servlet-mapping>
</web-app>