<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" version="4.0">
  <display-name>KaamChaluERP</display-name>
  
   <!-- ============================= -->
    <!-- Welcome File -->
    <!-- ============================= -->
	  <welcome-file-list>
	    <welcome-file>index.html</welcome-file>
	  </welcome-file-list>
  
    <!-- ============================= -->
    <!-- Context Parameters (Global) -->
    <!-- ============================= -->
    <context-param>
        <param-name>appName</param-name>
        <param-value>KaamChaluERP</param-value>
    </context-param>
    
  
    <!-- ============================= -->
    <!-- Registration Servlet -->
    <!-- ============================= -->
    <servlet>
        <servlet-name>RegistrationServlet</servlet-name>
        <servlet-class>Registration.Registration</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegistrationServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    
    <!-- ============================= -->
    <!-- Login Servlet -->
    <!-- ============================= -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>Login.Login</servlet-class>

        <init-param>
            <param-name>successPage</param-name>
            <param-value>index.html</param-value>
        </init-param>
    </servlet>
    
     <!-- ============================= -->
    <!-- Employees Servlet -->
    <!-- ============================= -->
<servlet>
    <servlet-name>EmployeesServlet</servlet-name>
    <servlet-class>Employees.Employees</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>EmployeesServlet</servlet-name>
    <url-pattern>/employees</url-pattern>
</servlet-mapping>

 <!-- ============================= -->
    <!-- Inventory Servlet -->
    <!-- ============================= -->
    <servlet>
        <servlet-name>InventoryServlet</servlet-name>
        <servlet-class>Inventory.Inventory</servlet-class>

        <init-param>
            <param-name>successPage</param-name>
            <param-value>inventory.html</param-value>
        </init-param>
    </servlet>
    
     <!-- ============================= -->
    <!-- Reports Servlet -->
    <!-- ============================= -->
    <servlet>
        <servlet-name>ReportsServlet</servlet-name>
        <servlet-class>Reports.Reports</servlet-class>

        <init-param>
            <param-name>successPage</param-name>
            <param-value>reports.html</param-value>
        </init-param>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    
</web-app>